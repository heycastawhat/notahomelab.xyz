---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Storage - notahomelab">
    <div class="min-h-screen flex items-center justify-center px-4">
        <div class="text-center max-w-lg">
            <h1 class="text-3xl md:text-4xl font-bold text-peach mb-8">
                40 TB storage breakdown
            </h1>
            <div class="space-y-4 text-left">
                <div class="rounded-xl border border-surface0 bg-mantle p-5">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-subtext1 font-semibold">Backups</span>
                        <span class="text-lavender font-bold">3 TB</span>
                    </div>
                    <div
                        class="w-full h-3 rounded-full bg-surface0 overflow-hidden"
                    >
                        <div
                            class="h-full rounded-full bg-lavender"
                            style="width: 7.5%"
                        >
                        </div>
                    </div>
                </div>
                <div class="rounded-xl border border-surface0 bg-mantle p-5">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-subtext1 font-semibold">Media</span>
                        <span class="text-peach font-bold">600 GB</span>
                    </div>
                    <div
                        class="w-full h-3 rounded-full bg-surface0 overflow-hidden"
                    >
                        <div
                            class="h-full rounded-full bg-peach"
                            style="width: 1.5%"
                        >
                        </div>
                    </div>
                </div>
                <div class="rounded-xl border border-surface0 bg-mantle p-5">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-subtext1 font-semibold"
                            >Actual important data</span
                        >
                        <span class="text-green font-bold">100 GB</span>
                    </div>
                    <div
                        class="w-full h-3 rounded-full bg-surface0 overflow-hidden"
                    >
                        <div
                            class="h-full rounded-full bg-green"
                            style="width: 0.25%"
                        >
                        </div>
                    </div>
                </div>
                <div class="rounded-xl border border-surface0 bg-mantle p-5">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-subtext1 font-semibold">Empty</span>
                        <span class="text-mauve font-bold">~36.3 TB</span>
                    </div>
                    <div
                        class="w-full h-3 rounded-full bg-surface0 overflow-hidden"
                    >
                        <div
                            class="h-full rounded-full bg-mauve"
                            style="width: 90.75%"
                        >
                        </div>
                    </div>
                </div>
            </div>
            <p class="text-overlay0 mt-8 text-sm">
                3.7 TB used out of 40. I'll fill it eventually. Probably.
            </p>
            <a
                href="/"
                class="inline-block mt-8 text-sm px-4 py-1.5 rounded-lg border border-surface0 text-subtext1 hover:border-mauve hover:text-text transition-colors"
            >
                ← Go back
            </a>
        </div>
    </div>
</Layout>
