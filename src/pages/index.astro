---
import Layout from "../layouts/Layout.astro";

const mySetup = [
    {
        title: "Synology RS818+",
        description:
            "Yes, I need it and its 40tbs of storage. Ignore the fact im only using 1tb.",
    },
    {
        title: "Raspberry Pi 4 2GB (Home Assistant)",
        description: "Automating lights I could just flip manually.",
    },
    {
        title: "Sky Broadband ISP Modem",
        description: "It... works?",
    },
    {
        title: "Google Nest Wifi (4 Units)",
        description: "Subpar access points that create a second nat!",
    },
    {
        title: "Docker",
        description:
            "Everything lives in a container. I have commitment issues.",
    },
    {
        title: "TP Link Deco BE25",
        description: "DID SOMEONE SAY THIRD NAT?",
    },
];

const thingsIRun = [
    { title: "Home Assistant", description: "Smart home. Mostly." },
    {
        title: "Jellyfin",
        description: "<strong>Legally</strong> acquired media streaming.",
    },
    { title: "Music Assistant", description: "Because Spotify wasn't enough." },
    {
        title: "Synology Drive",
        description: "My own cloud. Take that, Google.",
    },
    { title: "Tailscale", description: "VPN that sometimes just works." },
    {
        title: "Cloudflare Tunnels",
        description: "Port forwarding is hard on 2 nats, let alone 3.",
    },
];

const theirSetup = [
    {
        title: "UniFi Dream Machine Pro",
        description: "objectively better than my networking, but at what cost",
    },
    {
        title: "USW 24 PoE",
        description: "my TP-Link 8 port something is fine actually",
    },
    { title: "Synology NAS", description: "suspicious NAS noises" },
    {
        title: "Fedora Server",
        description: "50 containers. i have 10. totally comparable.",
    },
    { title: "Docker", description: "I use docker too" },
    { title: "Home Assistant", description: "wait you have this too??" },
];
---

<Layout title="not a homelab">
    <!-- Header -->
    <header
        class="w-full border-b border-surface0 bg-base/50 sticky top-0 backdrop-blur-xl z-50"
    >
        <nav class="max-w-4xl mx-auto h-14 flex flex-row items-center px-4">
            <span class="text-lg font-bold text-mauve">notahomelab</span>
            <div class="grow"></div>
            <a
                href="/signin"
                class="text-sm px-4 py-1.5 rounded-lg border border-surface0 text-subtext1 hover:border-mauve hover:text-text transition-colors"
            >
                Sign in
            </a>
        </nav>
    </header>

    <!-- Hero -->
    <section class="py-16 md:py-20 flex items-center justify-center px-4">
        <div class="text-center max-w-3xl">
            <h1 class="text-5xl md:text-8xl font-bold leading-tight">
                this is <span class="text-mauve">not</span><br />a homelab
            </h1>
            <p class="text-overlay0 text-lg mt-4">The domain even says so.</p>
        </div>
    </section>

    <!-- Stats -->
    <section class="max-w-4xl mx-auto px-4 py-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <a
                href="/network"
                class="stat-link rounded-xl border border-surface0 bg-mantle p-6 text-center"
            >
                <p class="text-3xl md:text-4xl font-bold text-mauve">3</p>
                <p class="text-subtext0 text-sm mt-1">NATs deep</p>
            </a>
            <a
                href="#services"
                class="stat-link rounded-xl border border-surface0 bg-mantle p-6 text-center"
            >
                <p class="text-3xl md:text-4xl font-bold text-green">6</p>
                <p class="text-subtext0 text-sm mt-1">Services running</p>
            </a>
            <a
                href="/storage"
                class="stat-link rounded-xl border border-surface0 bg-mantle p-6 text-center"
            >
                <p class="text-3xl md:text-4xl font-bold text-peach">40 TB</p>
                <p class="text-subtext0 text-sm mt-1">Storage available</p>
            </a>
            <a
                href="/storage"
                class="stat-link rounded-xl border border-surface0 bg-mantle p-6 text-center"
            >
                <p class="text-3xl md:text-4xl font-bold text-lavender">
                    ~1 TB
                </p>
                <p class="text-subtext0 text-sm mt-1">Actually used</p>
            </a>
        </div>
    </section>

    <!-- My Setup -->
    <section id="setup" class="max-w-4xl mx-auto px-4 py-20">
        <h2 class="text-2xl font-bold mb-6">The setup</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
            {
                mySetup.map((item) => (
                    <div class="setup-card rounded-xl p-7">
                        <h3 class="text-mauve font-semibold text-xl">
                            {item.title}
                        </h3>
                        <p class="text-subtext0 mt-3">{item.description}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- Things I Run -->
    <section id="services" class="max-w-4xl mx-auto px-4 py-20 scroll-mt-20">
        <h2 class="text-2xl font-bold mb-6">Things I run</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
            {
                thingsIRun.map((item) => (
                    <div class="setup-card rounded-xl p-7">
                        <h3 class="text-green font-semibold text-xl">
                            {item.title}
                        </h3>
                        <p
                            class="text-subtext0 mt-3"
                            set:html={item.description}
                        />
                    </div>
                ))
            }
        </div>
    </section>

    <!-- Why this is not a homelab -->
    <section class="max-w-4xl mx-auto px-4 py-20">
        <h2 class="text-2xl font-bold mb-6">
            Why this is <span class="text-mauve">not</span> a homelab
        </h2>
        <ul class="space-y-3 text-subtext0 text-lg">
            <li>It's in my TV Cabinet, not a dedicated server room</li>
            <li>
                I don't own a rack (the RS818+ is rackmountable but that doesn't
                count)
            </li>
            <li>I have fewer than 10 services (approximately)</li>
            <li>The NATs are accidental, not architectural</li>
            <li>A real homelab would have working auth</li>
        </ul>
    </section>

    <!-- Meanwhile on r/homelab -->
    <section class="max-w-4xl mx-auto px-4 py-20">
        <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold">
                Meanwhile over at <span class="text-lavender"
                    >notoverkill.com</span
                >
            </h2>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-surface0">
                        <th class="py-3 px-4 text-overlay0 text-sm font-normal"
                        ></th>
                        <th class="py-3 px-4 text-mauve font-semibold"
                            >notahomelab</th
                        >
                        <th class="py-3 px-4 text-lavender font-semibold"
                            >notoverkill</th
                        >
                    </tr>
                </thead>
                <tbody class="text-subtext0">
                    <tr class="border-b border-surface0/50">
                        <td class="py-3 px-4 text-subtext1 font-semibold"
                            >Router</td
                        >
                        <td class="py-3 px-4">ISP modem</td>
                        <td class="py-3 px-4">UniFi Dream Machine Pro</td>
                    </tr>
                    <tr class="border-b border-surface0/50">
                        <td class="py-3 px-4 text-subtext1 font-semibold"
                            >Switch</td
                        >
                        <td class="py-3 px-4">TP-Link 8 port something</td>
                        <td class="py-3 px-4">USW 24 PoE</td>
                    </tr>
                    <tr class="border-b border-surface0/50">
                        <td class="py-3 px-4 text-subtext1 font-semibold"
                            >NAS</td
                        >
                        <td class="py-3 px-4">Synology RS818+</td>
                        <td class="py-3 px-4">yes</td>
                    </tr>
                    <tr class="border-b border-surface0/50">
                        <td class="py-3 px-4 text-subtext1 font-semibold"
                            >Server</td
                        >
                        <td class="py-3 px-4"
                            >Raspberry Pi 4 (2GB) + Synology RS818+</td
                        >
                        <td class="py-3 px-4">Fedora Server</td>
                    </tr>
                    <tr class="border-b border-surface0/50">
                        <td class="py-3 px-4 text-subtext1 font-semibold"
                            >Containers</td
                        >
                        <td class="py-3 px-4">10</td>
                        <td class="py-3 px-4">50</td>
                    </tr>
                    <tr class="border-b border-surface0/50">
                        <td class="py-3 px-4 text-subtext1 font-semibold"
                            >NATs</td
                        >
                        <td class="py-3 px-4 text-mauve font-bold">3</td>
                        <td class="py-3 px-4"
                            >1 <span class="text-overlay0 text-sm"
                                >(boring)</span
                            ></td
                        >
                    </tr>
                    <tr class="border-b border-surface0/50">
                        <td class="py-3 px-4 text-subtext1 font-semibold"
                            >Home Assistant</td
                        >
                        <td class="py-3 px-4">yes</td>
                        <td class="py-3 px-4">yes</td>
                    </tr>
                    <tr>
                        <td class="py-3 px-4 text-subtext1 font-semibold"
                            >Auth</td
                        >
                        <td class="py-3 px-4 text-red">lol</td>
                        <td class="py-3 px-4">probably works</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <!-- Closing -->
    <section class="max-w-3xl mx-auto px-4 py-24 text-center">
        <h2 class="text-2xl md:text-3xl font-bold leading-relaxed">
            See? <span class="text-green">Totally normal.</span><br />
            A few nats and a
            <span class="text-peach">slightly large</span> amount of storage doesn't
            make it a homelab.
        </h2>
    </section>

    <!-- Footer -->
    <footer
        class="border-t border-surface0 py-8 px-4 text-center text-sm text-overlay0"
    >
        <p>
            built with <span class="text-red">astro</span> ·
            <a
                href="https://github.com/heycastawhat/notahomelab.xyz"
                target="_blank"
                class="text-lavender hover:underline">source</a
            >
        </p>
    </footer>
</Layout>

<style>
    .stat-link {
        display: block;
        text-decoration: none;
        transition:
            border-color 0.2s,
            transform 0.2s;
    }
    .stat-link:hover {
        border-color: var(--color-surface2);
        transform: translateY(-2px);
    }

    .setup-card {
        background: var(--color-mantle);
        border: 1px solid var(--color-surface0);
        transition:
            border-color 0.2s,
            box-shadow 0.2s,
            transform 0.2s;
    }
    .setup-card:hover {
        border-color: var(--color-mauve);
        box-shadow: 0 0 20px
            color-mix(in oklab, var(--color-mauve) 15%, transparent);
        transform: translateY(-2px);
    }

    @keyframes scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }
    .animate-scroll {
        animation: scroll 45s linear infinite;
    }
    .animate-scroll:hover {
        animation-play-state: paused;
    }
</style>
