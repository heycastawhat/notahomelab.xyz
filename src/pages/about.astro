---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About - notahomelab" description="who runs this and why. the answers may disappoint you.">
    <div class="min-h-screen flex items-center justify-center px-4">
        <div class="text-center max-w-lg">
            <h1 class="text-3xl md:text-4xl font-bold text-mauve mb-8">
                About
            </h1>
            <p class="text-subtext0 text-lg leading-relaxed">
                This site is run by one person with a Synology NAS in their bedroom,
                a Raspberry Pi automating lights they could just flip manually,
                and three accidental NATs. There is no team. There is no budget.
                Authentik has never worked. The 40TB of storage is 90% empty.
                This is not a homelab.
            </p>
            <a
                href="/"
                class="inline-block mt-8 text-sm px-4 py-1.5 rounded-lg border border-surface0 text-subtext1 hover:border-mauve hover:text-text transition-colors"
            >
                ← Go back
            </a>
        </div>
    </div>
</Layout>
