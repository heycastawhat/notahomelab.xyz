---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - notahomelab">
    <div class="min-h-screen flex items-center justify-center px-4">
        <div class="text-center max-w-md">
            <h1 class="text-5xl md:text-6xl font-bold text-mauve mb-4">
                404
            </h1>
            <p class="text-subtext0 text-lg">
                This page does not exist.
            </p>
            <p class="text-subtext0 text-lg mt-1">
                Neither does this homelab.
            </p>
            <a
                href="/"
                class="inline-block mt-8 text-sm px-4 py-1.5 rounded-lg border border-surface0 text-subtext1 hover:border-mauve hover:text-text transition-colors"
            >
                ← Go back
            </a>
        </div>
    </div>
</Layout>
