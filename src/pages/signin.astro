---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Sign in - notahomelab">
    <div class="min-h-screen flex items-center justify-center px-4">
        <div class="text-center max-w-md">
            <h1 class="text-3xl md:text-4xl font-bold text-mauve mb-4">
                Hold on.
            </h1>
            <p class="text-subtext0 text-lg">
                We haven't got Authentik working yet, be patient.
            </p>
            <a
                href="/"
                class="inline-block mt-8 text-sm px-4 py-1.5 rounded-lg border border-surface0 text-subtext1 hover:border-mauve hover:text-text transition-colors"
            >
                ← Go back
            </a>
        </div>
    </div>
</Layout>
